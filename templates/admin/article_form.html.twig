{% extends 'base.html.twig' %}

{% block title %}CinéLog - {{ title }}{% endblock %}

{% block body %}
    <h1 class="mb-4">{{ title }}</h1>

    {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.title, 'Titre') }}
            {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="mb-3">
            {{ form_label(form.content, 'Contenu') }}
            {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 10}}) }}
        </div>
        <div class="mb-3">
            {{ form_label(form.category, 'Catégorie') }}
            {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
        </div>
        <div class="mb-3">
            {{ form_label(form.tags, 'Tags') }}
            {{ form_widget(form.tags, {'attr': {'class': 'form-select'}}) }}
        </div>
        <button type="submit" class="btn btn-dark">Enregistrer</button>
        <a href="{{ path('app_admin_index') }}" class="btn btn-secondary ms-2">Annuler</a>
    {{ form_end(form) }}
{% endblock %}