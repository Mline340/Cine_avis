{% extends 'base.html.twig' %}

{% block title %}CinéLog - Administration{% endblock %}

{% block body %}
    <h1 class="mb-4">⚙️ Espace Admin</h1>

    {# Articles #}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📝 Articles</h3>
        <a href="{{ path('app_admin_article_new') }}" class="btn btn-dark btn-sm">+ Nouvel article</a>
    </div>

    <table class="table table-striped mb-5">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Catégorie</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for article in articles %}
                <tr>
                    <td>{{ article.title }}</td>
                    <td>{{ article.category ? article.category.name : '-' }}</td>
                    <td>{{ article.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <a href="{{ path('app_admin_article_edit', {id: article.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                        <form method="post" action="{{ path('app_admin_article_delete', {id: article.id}) }}" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer cet article ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-muted">Aucun article.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    {# Catégories #}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📂 Catégories</h3>
        <a href="{{ path('app_admin_category_new') }}" class="btn btn-dark btn-sm">+ Nouvelle catégorie</a>
    </div>

    <table class="table table-striped mb-5">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Slug</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
                <tr>
                    <td>{{ category.name }}</td>
                    <td>{{ category.slug }}</td>
                    <td>
                        <form method="post" action="{{ path('app_admin_category_delete', {id: category.id}) }}" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer cette catégorie ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3" class="text-muted">Aucune catégorie.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
